{
  "name": "@verevoir/access",
  "version": "0.2.0-beta.1",
  "description": "Identity resolution, policy evaluation, and workflow state machines",
  "homepage": "https://verevoir.io",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./google": {
      "types": "./dist/google.d.ts",
      "import": "./dist/google.js",
      "require": "./dist/google.cjs"
    },
    "./test-accounts": {
      "types": "./dist/test-accounts.d.ts",
      "import": "./dist/test-accounts.js",
      "require": "./dist/test-accounts.cjs"
    },
    "./role-store": {
      "types": "./dist/role-store.d.ts",
      "import": "./dist/role-store.js",
      "require": "./dist/role-store.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:verevoir/access.git"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "google-auth-library": "^9.0.0",
    "@verevoir/storage": "0.3.0-beta.1"
  },
  "peerDependenciesMeta": {
    "google-auth-library": {
      "optional": true
    },
    "@verevoir/storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@verevoir/storage": "0.3.0-beta.1",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
